{
  "name": "projectalkanes-jobs",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build-tests": "tsc -p tests",
    "watch": "tsc -w",
    "clean": "rm -rf dist",
    "prestart": "npm run clean && npm run build",
    "start": "func start",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage && open coverage/index.html",
    "lint": "eslint",
    "plop": "cross-env NODE_OPTIONS='--import tsx' plop --plopfile=plopfile.ts"
  },
  "dependencies": {
    "@azure/functions": "^4.12.0",
    "@dotenvx/dotenvx": "^1.59.1",
    "bitcoinjs-lib": "^7.0.1",
    "js-big-decimal": "^2.2.0",
    "mongodb": "^7.1.1",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/seedrandom": "^3.0.8",
    "@vitest/coverage-istanbul": "^4.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "jiti": "^2.6.1",
    "mongodb-memory-server": "^11.0.1",
    "plop": "^4.0.5",
    "seedrandom": "^3.0.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.1",
    "vitest-fetch-mock": "^0.4.5"
  },
  "main": "dist/src/{index.js,functions/*.js}"
}
